{
  "name": "toogle-superpowers",
  "version": "0.1.0",
  "description": "Pi extension that gates obra/superpowers behind a /superpowers slash command: skills are discovered and the using-superpowers bootstrap is injected only after activation.",
  "type": "module",
  "keywords": [
    "pi-package",
    "superpowers",
    "skills",
    "extension"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JulianS-Uni/toogle-superpowers.git"
  },
  "pi": {
    "extensions": [
      "./extensions/toogle-superpowers.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node test/smoke.mjs"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@types/node": "^26.1.0",
    "jiti": "^2.4.0",
    "typescript": "^5.6.0"
  }
}
